{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mlbb-build-analyser/schema/emblem.schema.json",
  "title": "MLBB Emblem (max level)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "stats"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "name": { "type": "string" },
    "lastPatch": { "type": "string" },
    "iconAsset": { "type": "string" },
    "stats": {
      "type": "object",
      "description": "Max-level stat grants. Keys restricted to the closed itemStatKey set; hybrid defense/regen is pre-expanded into concrete keys.",
      "propertyNames": { "$ref": "common.defs.schema.json#/$defs/itemStatKey" },
      "additionalProperties": {
        "oneOf": [
          { "type": "number" },
          { "type": "object", "additionalProperties": false, "required": ["value", "unique"],
            "properties": { "value": { "type": "number" }, "unique": { "type": "string", "minLength": 1 } } }
        ]
      }
    },
    "sources": { "type": "array", "items": { "$ref": "common.defs.schema.json#/$defs/source" } }
  }
}
